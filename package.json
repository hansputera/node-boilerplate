{
  "name": "project-name-here",
  "version": "0.0.1",
  "description": "project description here",
  "main": "./dist/index.js",
  "scripts": {
    "prepare": "node preinstall.js",
    "dev": "tsup --watch",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint --write ./src",
    "format": "biome format --write ./src",
    "check": "biome check --write ./src",
    "test": "vitest run",
    "test:watch": "vitest",
    "hook": "node hook.js"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.27.0",
  "type": "module",
  "keywords": [
    "project keywords"
  ],
  "author": {
    "name": "Hanif Dwy Putra S",
    "email": "hanifdwyputrasembiring@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@swc/core": "^1.15.18",
    "@types/node": "^25.3.3",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3"
  }
}
